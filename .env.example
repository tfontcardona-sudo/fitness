# ============================================================
# SISTEMA DE ASESORÍAS FITNESS — Variables de entorno
# Copia este archivo a .env y rellena los valores.
# ============================================================

# --- IA (Anthropic) ---
ANTHROPIC_API_KEY=
MODEL_HEAVY=claude-opus-4-8
MODEL_LIGHT=claude-haiku-4-5-20251001

# --- Base de datos ---
# En Docker se resuelve contra el servicio "db"
DATABASE_URL=postgresql+psycopg://fitness:fitness@db:5432/fitness
POSTGRES_USER=fitness
POSTGRES_PASSWORD=fitness
POSTGRES_DB=fitness

# --- Seguridad ---
JWT_SECRET=cambia-esto-por-una-cadena-larga-aleatoria
PORTAL_TOKEN_SECRET=cambia-esto-por-otra-cadena-larga-aleatoria

# --- Usuarios admin (seed inicial, single-tenant) ---
ADMIN_1_USER=coach1
ADMIN_1_PASS=cambiar-en-produccion
ADMIN_2_USER=coach2
ADMIN_2_PASS=cambiar-en-produccion

# --- URLs y dominio ---
# DOMAIN vacío => Caddy sirve en :80 sin TLS (dev / pruebas en VPS sin dominio)
# DOMAIN=app.tudominio.com => Caddy obtiene certificado HTTPS automático
DOMAIN=
BASE_URL=http://localhost
STORAGE_PATH=./storage

# --- Email (SMTP) ---
# Envío real desde Gmail (david.dqr57@gmail.com). SMTP_PASS es una CONTRASEÑA DE
# APLICACIÓN de Google (16 letras), NO la contraseña normal: Cuenta de Google →
# Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=david.dqr57@gmail.com
SMTP_PASS=
SMTP_FROM=David Quiceno <david.dqr57@gmail.com>
# Debe ser true para que salgan los correos (acceso al portal, plan, feedback…).
EMAILS_ENABLED=true

# --- Web Push (notificaciones del portal) ---
# Generar UNA vez y no cambiar (invalidaría las suscripciones existentes):
#   docker compose exec api python -m scripts.generate_vapid_keys
# La entrega real de push requiere HTTPS (DOMAIN configurado); en localhost
# solo funciona probando desde Chrome en el propio PC.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-email@ejemplo.com
PUSH_ENABLED=true

# --- Pagos (Stripe) ---
# Clave secreta de tu cuenta (Stripe → Desarrolladores → Claves API). Usa la
# LIVE (sk_live_…) para cobrar de verdad o la de prueba (sk_test_…) para testear.
STRIPE_SECRET_KEY=
# Secreto del webhook (Stripe → Desarrolladores → Webhooks → tu endpoint). Empieza por whsec_
STRIPE_WEBHOOK_SECRET=
# ID del PRECIO de cada plan × duración (Stripe → Productos → tu producto →
# el precio de esa duración → price_…). 1M = mensual · 3M = trimestral ·
# 6M = semestral. Nueve en total (¡el price_…, no el prod_…!).
STRIPE_PRICE_START_1M=
STRIPE_PRICE_START_3M=
STRIPE_PRICE_START_6M=
STRIPE_PRICE_FULL_1M=
STRIPE_PRICE_FULL_3M=
STRIPE_PRICE_FULL_6M=
STRIPE_PRICE_PRO_1M=
STRIPE_PRICE_PRO_3M=
STRIPE_PRICE_PRO_6M=
# "payment" (pago único) o "subscription" (cuota recurrente), según cómo hayas
# creado los precios en Stripe.
STRIPE_MODE=payment

# --- Google Calendar / Meet (videollamadas Pro) ---
# Para agendar videollamadas con enlace de Meet e invitar al cliente. Crea un
# proyecto en Google Cloud → habilita la API de Google Calendar → Credenciales →
# "ID de cliente de OAuth" tipo "Aplicación web". En "URIs de redirección
# autorizados" añade EXACTAMENTE:  {BASE_URL o DOMAIN}/api/google/oauth/callback
# (p. ej. https://app.tudominio.com/api/google/oauth/callback). Guía: GOOGLE.md.
# Sin estas claves la integración queda desactivada (sigue el flujo manual).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Calendario donde se crean los eventos: "primary" (el principal del coach) o el
# ID de un calendario concreto (Configuración del calendario → Integrar → ID).
GOOGLE_CALENDAR_ID=primary
# Email de la cuenta de Google de la ASESORÍA. Al pulsar "Conectar", Google abre
# directamente con esta cuenta (no con la que el navegador tenga por defecto), así
# no conectas por error tu cuenta personal. Déjalo vacío si quieres elegir a mano.
GOOGLE_LOGIN_HINT=asesoriasdqr@gmail.com

# --- Comportamiento ---
AUTO_PILOT_DEFAULT=false
TZ=Europe/Madrid
