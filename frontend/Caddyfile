# Si DOMAIN está definido, Caddy sirve en ese dominio con HTTPS automático.
# Si está vacío, sirve en :80 (pruebas locales o VPS sin dominio todavía).
{$DOMAIN::80} {
	encode gzip

	handle /api/* {
		# X-Real-IP = IP real del cliente que ve Caddy ({remote_host}); no es
		# falseable por el cliente. El backend la usa para limitar por IP en
		# lugar de un cubo global compartido (un pico dejaría sin login a todos).
		reverse_proxy api:8000 {
			header_up X-Real-IP {remote_host}
		}
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
